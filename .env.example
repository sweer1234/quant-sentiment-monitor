QSM_APP_NAME=quant-sentiment-monitor
QSM_ENV=dev
QSM_PUBLIC_API_TOKEN=dev-public-token
QSM_SOURCE_REGISTRY_DEFAULT=configs/sources_registry.default.yaml
QSM_SOURCE_REGISTRY_OVERRIDE=configs/sources_registry.override.yaml
QSM_SOURCE_WEIGHT_RULES=configs/source_weight_rules.yaml
QSM_MANUAL_INPUT_RULES=configs/manual_input_rules.yaml
QSM_MULTI_USER_RULES=configs/multi_user_rules.yaml
QSM_TOPIC_TAXONOMY=configs/topic_taxonomy.yaml
QSM_INVESTMENT_EVENT_CATALOG=configs/investment_event_catalog.yaml
QSM_ALERT_GOVERNANCE_RULES=configs/alert_governance_rules.yaml
QSM_SOURCE_COMPLIANCE_REGISTRY=configs/source_compliance_registry.yaml
QSM_PORTFOLIO_IMPACT_RULES=configs/portfolio_impact_rules.yaml
QSM_FEEDBACK_LEARNING_RULES=configs/feedback_learning_rules.yaml
QSM_BILLING_SLA_RULES=configs/billing_sla_rules.yaml
QSM_EVENT_CALENDAR_RULES=configs/event_calendar_rules.yaml
QSM_WEBHOOK_DELIVERY_RULES=configs/webhook_delivery_rules.yaml
QSM_STATE_PATH=data/state.json
QSM_STATE_BACKEND=file
QSM_DATABASE_URL=sqlite:///data/qsm.db
QSM_STATE_SQL_TABLE=qsm_state
QSM_QUEUE_BACKEND=local
QSM_QUEUE_REDIS_URL=redis://localhost:6379/0
QSM_COLLECTOR_TASK_QUEUE_KEY=qsm:collector:tasks
QSM_MODEL_BACKEND=local
QSM_MODEL_SERVICE_URL=http://127.0.0.1:9000/infer
QSM_MODEL_SERVICE_TIMEOUT_SEC=3
QSM_NOTIFICATION_BACKEND=mock
QSM_SMTP_HOST=127.0.0.1
QSM_SMTP_PORT=25
QSM_SMTP_USER=
QSM_SMTP_PASSWORD=
QSM_SMTP_USE_TLS=false
QSM_NOTIFY_EMAIL_FROM=qsm-alerts@example.com
QSM_NOTIFY_EMAIL_TO=
QSM_IM_WEBHOOK_URL=
QSM_IM_WEBHOOK_TIMEOUT_SEC=5
